# Copy to .env and fill in real values for local dev.

# --- Database ---
DATABASE_URL=postgresql+psycopg://mos:mos_dev@localhost:5432/mos

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO dev / S3 prod) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=mos
STORAGE_SECRET_KEY=mos_dev_secret
STORAGE_BUCKET=mos-artifacts

# --- Intent LLM (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# --- Feature flags (Phase 1) ---
MOS_FEATURE_RENDER=true
MOS_FEATURE_COST=true
MOS_FEATURE_SOP=true

# --- Environment name ---
MOS_ENV=dev
